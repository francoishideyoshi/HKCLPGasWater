# Copy to .env for LOCAL development only. NEVER commit a real .env.
# In production these go into GitHub Actions Secrets (Settings > Secrets and
# variables > Actions), NOT into any file.
#
# Leave a provider's credentials blank (or set its *_PROVIDER_MODE=manual) to
# skip scraping it -- the orchestrator will use manual_data.json / last-known.

# --- CLP (electricity) ---
# NOTE: CLP likely uses passwordless OTP / iAM Smart login (since Sep 2025) and
# may NOT be automatable. If so, set CLP_PROVIDER_MODE=manual and edit
# manual_data.json instead.
CLP_USERNAME=
CLP_PASSWORD=
CLP_PROVIDER_MODE=auto

# --- Towngas (gas) ---
TOWNGAS_USERNAME=
TOWNGAS_PASSWORD=
TOWNGAS_PROVIDER_MODE=auto

# --- WSD (water) ---
# WARNING: WSD locks the account for 24h after 5 consecutive login failures.
# Double-check these are correct; the scraper makes a single attempt, no retry.
WSD_USERNAME=
WSD_PASSWORD=
WSD_PROVIDER_MODE=auto
